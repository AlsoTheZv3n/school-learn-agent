# Local dev uses host port 5433 (docker-compose) to avoid a native PostgreSQL on 5432.
# 127.0.0.1 (not localhost) since the container is published on the IPv4 loopback only.
DATABASE_URL=postgresql+psycopg://its:its_dev_pw@127.0.0.1:5433/its
DATA_MODE=mock          # mock | prod  (siehe docs/11)
MIN_COHORT_K=10
LLM_BACKEND=local       # local | frontier
LLM_API_KEY=
JWT_PUBLIC_KEY=
